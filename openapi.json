{
  "openapi": "3.1.0",
  "info": {
    "title": "Combined Noted from Lead Parser",
    "description": "Extract cleaned question-answer rows from Zoho Combined Notes from Lead PDFs uploaded in the conversation.",
    "version": "4.0.0"
  },
  "servers": [
    {
      "url": "https://combined-noted-from-lead-parser.onrender.com"
    }
  ],
  "paths": {
    "/parse": {
      "post": {
        "operationId": "parsePdf",
        "summary": "Parse Zoho Combined Notes from Lead PDF",
        "description": "Use the uploaded PDF from the current conversation. The file parameter must be named openaiFileIdRefs so ChatGPT sends file references.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "openaiFileIdRefs": {
                    "type": "array",
                    "description": "Array of PDF file references from the conversation. Use the uploaded Zoho Combined Notes from Lead PDF.",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "openaiFileIdRefs"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rows": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "rows"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}