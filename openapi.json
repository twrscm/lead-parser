{
  "openapi": "3.1.0",
  "info": {
    "title": "Combined Noted from Lead Parser",
    "version": "1.0.0",
    "description": "Upload a Zoho Combined Notes from Lead PDF and get deterministic question-answer rows back."
  },
  "servers": [
    {
      "url": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/parse": {
      "post": {
        "operationId": "parsePdf",
        "summary": "Parse a Combined Notes from Lead PDF",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "extracted_text": {"type": "string"},
                    "rows": {"type": "array", "items": {"type": "string"}},
                    "pairs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "question": {"type": "string"},
                          "answer": {"type": "string"}
                        },
                        "required": ["question", "answer"]
                      }
                    }
                  },
                  "required": ["rows", "pairs"]
                }
              }
            }
          }
        }
      }
    }
  }
}
